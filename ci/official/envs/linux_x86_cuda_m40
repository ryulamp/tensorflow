source ci/official/envs/linux_x86_cuda
# Override compute capabilities for NVIDIA M40 (Maxwell, cc 5.2)
# The default cuda12_version config sets sm_60+, but M40 requires sm_52.
# We must stay on CUDA 12.x since CUDA 13 dropped sm_5x support.
TFCI_BAZEL_COMMON_ARGS="$TFCI_BAZEL_COMMON_ARGS --repo_env=HERMETIC_CUDA_COMPUTE_CAPABILITIES=sm_52"
TFCI_LIB_SUFFIX="-gpu-m40-linux-x86_64"
